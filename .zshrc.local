# Load secrets — prefer systemd user environment (seeded by op-env-session
# at KDE login), fall back to `op inject` for shells outside the session
# (e.g., SSH). $OP_SESSION_LOADED is the marker set after a successful
# session-time inject.
if [ -z "$OP_SESSION_LOADED" ]; then
  _senv=$(systemctl --user show-environment 2>/dev/null)
  if echo "$_senv" | grep -q '^OP_SESSION_LOADED='; then
    _vars="OP_SESSION_LOADED $(grep -oP '(?<=export )\w+' "$HOME/.config/zshrc-env.tmpl" 2>/dev/null)"
    for _v in ${=_vars}; do
      eval "export $(echo "$_senv" | grep "^${_v}=")"
    done
  elif command -v op >/dev/null 2>&1; then
    eval "$(op inject --account team-uceap -i "$HOME/.config/zshrc-env.tmpl" 2>/dev/null)"
  fi
  unset _senv _vars _v
fi

if [[ -n "${ANTHROPIC_FOUNDRY_API_KEY:-}" ]]; then
  export CLAUDE_CODE_USE_FOUNDRY="1"
  export ANTHROPIC_FOUNDRY_RESOURCE="uceap-claude-test-resource"
fi
