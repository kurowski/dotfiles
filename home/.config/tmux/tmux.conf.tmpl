set -g mouse on
set -g default-terminal "tmux-256color"

# Forward outer-terminal focus in/out events to apps inside panes (Claude Code,
# nvim) so they stop warning that focus tracking is unavailable.
set -g focus-events on

# Stop tmux from stripping OSC 8 hyperlinks on the way out to ghostty.
set -as terminal-features 'xterm*:hyperlinks'

# Plugins (managed by tpack — drop-in tpm replacement, installed by setup.sh).
set -g @plugin 'catppuccin/tmux#v2.3.0'

set -g @catppuccin_flavor '{{ if hasTag "work" }}latte{{ else }}mocha{{ end }}'
set -g @catppuccin_window_status_style "rounded"

set -g status-right-length 100
set -g status-left-length 100
set -g status-left ""
set -g status-right "#{E:@catppuccin_status_application}"
set -ag status-right "#{E:@catppuccin_status_session}"

# Keep at the very bottom.
run 'tpack init'
