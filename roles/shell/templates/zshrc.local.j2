#
# .zshrc.local — machine-specific config, managed by ansible
# This file is not deployed to devcontainers.
#

{% if has_env_template | default(false) %}
# Load secrets — prefer systemd session (set by op-env-session at login),
# fall back to op inject (will prompt for biometric)
if [ -z "$OP_SESSION_LOADED" ]; then
  _senv=$(systemctl --user show-environment 2>/dev/null)
  if echo "$_senv" | grep -q '^OP_SESSION_LOADED='; then
    _vars="OP_SESSION_LOADED $(grep -oP '(?<=export )\w+' {{ ansible_env.HOME }}/.config/zshrc-env.tmpl 2>/dev/null)"
    for _v in ${=_vars}; do
      eval "export $(echo "$_senv" | grep "^${_v}=")"
    done
  elif command -v op >/dev/null 2>&1; then
    eval "$(op inject --account {{ op_account }} -i {{ ansible_env.HOME }}/.config/zshrc-env.tmpl 2>/dev/null)"
  fi
  unset _senv _vars _v
fi
{% endif %}

{% if 'work' in group_names %}
# Connect to Windows VM via RDP (camera/mic via rdpecam channel)
winvm() {
  local ip
  ip=$(sudo virsh domifaddr {{ win10_vm_name }} 2>/dev/null | awk '/ipv4/ {split($4,a,"/"); print a[1]}')
  if [ -z "$ip" ]; then
    echo "VM {{ win10_vm_name }} is not running. Start it with: sudo virsh start {{ win10_vm_name }}" >&2
    return 1
  fi
  local pass
  pass=$(op read "{{ win10_op_password_ref }}" --account {{ op_account }}) || return 1
  /usr/local/bin/sdl-freerdp /v:"$ip" /u:{{ username }} /p:"$pass" \
    /cert:tofu /dynamic-resolution /sound /microphone /dvc:rdpecam,quality:0
}
{% endif %}

{% if claude_foundry | default(false) %}
# Claude Code Foundry
export CLAUDE_CODE_USE_FOUNDRY="1"
export ANTHROPIC_FOUNDRY_RESOURCE="{{ claude_foundry_resource }}"
{% endif %}
